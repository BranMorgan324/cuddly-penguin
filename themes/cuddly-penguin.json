        "players": [
          {
            "cursor": "#F08030",
            "background": "#F08030",
            "selection": "#F0803040"
          },
          {
            "cursor": "#FFAD50",
            "background": "#FFAD50",
            "selection": "#FFAD5040"
          },
          {
            "cursor": "#70C878",
            "background": "#70C878",
            "selection": "#70C87840"
          },
          {
            "cursor": "#58A8E0",
            "background": "#58A8E0",
            "selection": "#58A8E040"
          },
          {
            "cursor": "#F060A0",
            "background": "#F060A0",
            "selection": "#F060A040"
          }
        ],

        "syntax": {
          "attribute": { "color": "#E0B858" },
          "boolean": { "color": "#F08030", "font_weight": 600 },
          "comment": { "color": "#5A6070", "font_style": "italic" },
          "comment.doc": { "color": "#7A8090", "font_style": "italic" },
          "constant": { "color": "#FFA040" },
          "constant.builtin": { "color": "#FFAD50" },
          "constructor": { "color": "#F08030" },
          "embedded": { "color": "#78C880" },
          "emphasis": { "color": "#F0EDE8", "font_style": "italic" },
          "emphasis.strong": { "color": "#F0EDE8", "font_weight": 700 },
          "enum": { "color": "#50C0C8" },
          "function": { "color": "#F0C830" },
          "function.builtin": { "color": "#F08030" },
          "function.method": { "color": "#FFAD50", "font_style": "italic" },
          "function.special": { "color": "#F08030", "font_weight": 600 },
          "hint": { "color": "#C0A0E0" },
          "keyword": { "color": "#FF6030", "font_weight": 700 },
          "keyword.directive": { "color": "#FFAD50" },
          "label": { "color": "#58A8E0" },
          "link_text": { "color": "#58A8E0", "font_style": "underline" },
          "link_uri": { "color": "#50B8C0", "font_style": "underline" },
          "number": { "color": "#F060A0" },
          "operator": { "color": "#F060A0" },
          "operator.derivative": { "color": "#F060A0" },
          "predictive": { "color": "#6870A0" },
          "preproc": { "color": "#E0B858" },
          "primary": { "color": "#C0A0E0" },
          "property": { "color": "#FFA060" },
          "punctuation": { "color": "#6870A0" },
          "punctuation.bracket": { "color": "#F0EDE8" },
          "punctuation.delimiter": { "color": "#9098B0" },
          "punctuation.list_marker": { "color": "#F08030", "font_weight": 700 },
          "punctuation.markup": { "color": "#9098B0" },
          "punctuation.special": { "color": "#F08030" },
          "string": { "color": "#78C880" },
          "string.escape": { "color": "#50B8C0" },
          "string.regex": { "color": "#50B8C0" },
          "string.special": { "color": "#88D890" },
          "string.special.symbol": { "color": "#FFAD50" },
          "tag": { "color": "#F08030" },
          "tag.doctype": { "color": "#6870A0" },
          "text.literal": { "color": "#78C880" },
          "title": { "color": "#F08030", "font_weight": 700 },
          "type": { "color": "#50C0C8" },
          "type.builtin": { "color": "#68B8F0" },
          "type.interface": { "color": "#50C0C8" },
          "type.super": { "color": "#50C0C8" },
          "variable": { "color": "#D0C8B8" },
          "variable.builtin": { "color": "#F08030" },
          "variable.member": { "color": "#FFA060" },
          "variable.parameter": { "color": "#C0B8A8", "font_style": "italic" },
          "variable.special": { "color": "#FFAD50" },
          "variant": { "color": "#C078D0" },
          "version_control.added": { "color": "#70C878" },
          "version_control.deleted": { "color": "#E06870" },
          "version_control.modified": { "color": "#FFAD50" },
          "version_control.conflict": { "color": "#E0B858" },
          "version_control.renamed": { "color": "#58A8E0" },
          "version_control.ignored": { "color": "#3E4456" }
        }

{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Cuddly Penguin",
  "author": "branmorgan",
  "themes": [
    {
      "name": "Cuddly Penguin",
      "appearance": "dark",
      "style": {
        "background.appearance": "blurred",

        "background": "#13161CCC",
        "editor.background": "#13161CCC",
        "editor.foreground": "#F0EDE8",
        "editor.gutter.background": "#13161CCC",
        "editor.active_line.background": "#22283A88",
        "editor.line_number": "#3E4456",
        "editor.active_line_number": "#F08030",
        "editor.indent_guide": "#252A3688",
        "editor.indent_guide_active": "#F0803066",
        "editor.invisible": "#2E3444",
        "editor.wrap_guide": "#1E2230",
        "editor.active_wrap_guide": "#252A36",
        "editor.document_highlight.read_background": "#50C0C81A",
        "editor.document_highlight.write_background": "#F0803066",
        "editor.subheader.background": "#1A1E2699",
        "editor.highlighted_line.background": "#22283A88",

        "ghost_element.background": "transparent",
        "ghost_element.hover": "#22283A",
        "ghost_element.active": "#2A3040",
        "ghost_element.selected": "#323850",
        "ghost_element.disabled": "#1A1E2666",

        "border": "#252A36",
        "border.variant": "#2E3444",
        "border.focused": "#F08030",
        "border.selected": "#F08030",
        "border.transparent": "transparent",
        "border.disabled": "#1E2230",

        "text": "#F0EDE8",
        "text.muted": "#C0B8A8",
        "text.placeholder": "#72685C",
        "text.disabled": "#4A4440",
        "text.accent": "#F08030",

        "surface.background": "#1A1E26CC",
        "elevated_surface.background": "#22283ACC",
        "panel.background": "#1A1E26CC",
        "panel.focused_border": "#F0803044",

        "status_bar.background": "#13161CCC",
        "title_bar.background": "#13161CCC",
        "title_bar.inactive_background": "#13161CAA",
        "toolbar.background": "#1A1E26CC",
        "tab_bar.background": "#13161CCC",
        "tab.inactive_background": "#1A1E2699",
        "tab.active_background": "#22283ACC",

        "drop_target.background": "#F0803022",

        "scrollbar.thumb.background": "#2E344488",
        "scrollbar.thumb.border": "#2E3444",
        "scrollbar.thumb.hover_background": "#3A4258",
        "scrollbar.track.background": "#13161C66",
        "scrollbar.track.border": "#1A1E2666",

        "element.background": "#1A1E26",
        "element.hover": "#22283A",
        "element.active": "#2A3040",
        "element.selected": "#323850",
        "element.disabled": "#1A1E2666",

        "icon": "#F0EDE8",
        "icon.muted": "#8A8070",
        "icon.disabled": "#4A4440",
        "icon.placeholder": "#72685C",
        "icon.accent": "#F08030",

        "created": "#70C878",
        "created.background": "#1E3028",
        "created.border": "#70C878",
        "modified": "#FFAD50",
        "modified.background": "#2E2A18",
        "modified.border": "#FFAD50",
        "deleted": "#E06870",
        "deleted.background": "#2E1C20",
        "deleted.border": "#E06870",
        "conflict": "#E0B858",
        "conflict.background": "#2E2A18",
        "conflict.border": "#E0B858",
        "ignored": "#3E4456",
        "ignored.background": "#13161C",
        "ignored.border": "#252A36",
        "renamed": "#58A8E0",
        "renamed.background": "#1C2838",
        "renamed.border": "#58A8E0",

        "error": "#E06870",
        "error.background": "#2E1C20",
        "error.border": "#E06870",
        "warning": "#E0B858",
        "warning.background": "#2E2A18",
        "warning.border": "#E0B858",
        "info": "#58A8E0",
        "info.background": "#1C2838",
        "info.border": "#58A8E0",
        "success": "#70C878",
        "success.background": "#1E3028",
        "success.border": "#70C878",
        "hint": "#C0A0E0",
        "hint.background": "#201C30",
        "hint.border": "#C0A0E0",
        "predictive": "#6870A0",
        "predictive.background": "#1A1E2A",
        "predictive.border": "#6870A0",
        "unreachable": "#3E4456",
        "unreachable.background": "#13161C",
        "unreachable.border": "#252A36",


        "terminal.ansi.yellow": "#E0B858",
        "terminal.ansi.blue": "#58A8E0",
        "terminal.ansi.magenta": "#C078D0",
        "terminal.ansi.cyan": "#50B8C0",
        "terminal.ansi.white": "#F0EDE8",
        "terminal.ansi.bright_black": "#3E4456",
        "terminal.ansi.bright_red": "#FF7880",
        "terminal.ansi.bright_green": "#80D888",
        "terminal.ansi.bright_yellow": "#F0C868",
        "terminal.ansi.bright_blue": "#68B8F0",
        "terminal.ansi.bright_magenta": "#D088E0",
        "terminal.ansi.bright_cyan": "#60C8D0",
        "terminal.ansi.bright_white": "#FFFFFF",
        "terminal.ansi.dim_black": "#13161C",
        "terminal.ansi.dim_red": "#C05860",
        "terminal.ansi.dim_green": "#509858",
        "terminal.ansi.dim_yellow": "#B09040",
        "terminal.ansi.dim_blue": "#4080B0",
        "terminal.ansi.dim_magenta": "#9058A0",
        "terminal.ansi.dim_cyan": "#388898",
        "terminal.ansi.dim_white": "#C0B8A8",

